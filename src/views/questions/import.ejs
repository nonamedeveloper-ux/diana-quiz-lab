<%- include('../partials/header') %>

<div class="max-w-2xl mx-auto space-y-6">

  <!-- Instructions -->
  <div class="bg-blue-50 border border-blue-200 rounded-xl p-5">
    <h2 class="font-semibold text-blue-800 mb-2 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Excel fayl formati
    </h2>
    <p class="text-sm text-blue-700 mb-3">Excel faylida quyidagi ustunlar bo'lishi kerak:</p>
    <div class="overflow-x-auto">
      <table class="text-xs w-full border-collapse">
        <thead>
          <tr class="bg-blue-100">
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">Question</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">A</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">B</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">C</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">D</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">Correct</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">Subject</th>
            <th class="px-2 py-1.5 text-left border border-blue-200 text-blue-800">Difficulty</th>
          </tr>
        </thead>
        <tbody>
          <tr class="bg-white">
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">2+2=?</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">3</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">4</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">5</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">6</td>
            <td class="px-2 py-1.5 border border-blue-100 font-bold text-green-700">B</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">Matematika</td>
            <td class="px-2 py-1.5 border border-blue-100 text-blue-700">easy</td>
          </tr>
        </tbody>
      </table>
    </div>
    <ul class="mt-3 text-xs text-blue-600 space-y-1">
      <li>• <strong>Correct</strong> ustuni A, B, C yoki D bo'lishi kerak</li>
      <li>• <strong>Subject</strong> ustuni bo'lsa, fan avtomatik yaratiladi</li>
      <li>• <strong>Difficulty</strong>: easy / medium / hard (ixtiyoriy)</li>
    </ul>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/questions/template"
        class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-700 hover:text-blue-900 underline">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Bo'sh shablon (.xlsx)
      </a>
      <span class="text-blue-300">|</span>
      <a href="/questions/sample"
        class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 hover:text-emerald-900 underline">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        63 ta namuna savol (.xlsx) — 7 fandan
      </a>
    </div>
  </div>

  <!-- Upload form -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
    <h2 class="font-semibold text-gray-800 mb-5">Excel fayl yuklash</h2>

    <form id="importForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Standart fan (ixtiyoriy)</label>
        <select name="defaultSubjectId" id="defaultSubjectId"
          class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="">Excel fayldan oladi</option>
          <% for (const s of subjects) { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% } %>
        </select>
        <p class="text-xs text-gray-400 mt-1">Agar Excel da Subject ustuni bo'lmasa, shu fan ishlatiladi</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Excel fayl (.xlsx, .xls) <span class="text-red-500">*</span></label>
        <div id="dropZone" class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center cursor-pointer hover:border-indigo-400 hover:bg-indigo-50/30 transition-colors">
          <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-sm text-gray-500 mb-1">Faylni bu yerga tashlang yoki</p>
          <label class="cursor-pointer inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors">
            Fayl tanlash
            <input type="file" id="excelFile" accept=".xlsx,.xls" class="hidden" required/>
          </label>
          <p id="fileName" class="text-xs text-gray-400 mt-2">Fayl tanlanmagan</p>
        </div>
      </div>

      <button type="submit" id="submitBtn"
        class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/></svg>
        Yuklash va Import Qilish
      </button>
    </form>
  </div>

  <!-- Result -->
  <div id="resultBox" class="hidden bg-white rounded-xl border border-gray-100 shadow-sm p-6">
    <h3 class="font-semibold text-gray-800 mb-4">Import natijasi</h3>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
        <p class="text-3xl font-bold text-green-700" id="resCreated">0</p>
        <p class="text-sm text-green-600 mt-1">Muvaffaqiyatli qo'shildi</p>
      </div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-3xl font-bold text-gray-600" id="resSkipped">0</p>
        <p class="text-sm text-gray-500 mt-1">O'tkazib yuborildi</p>
      </div>
    </div>
    <div id="resErrors" class="hidden">
      <p class="text-sm font-medium text-red-700 mb-2">Xatolar:</p>
      <ul id="resErrorList" class="text-xs text-red-600 space-y-1 max-h-40 overflow-y-auto bg-red-50 rounded-lg p-3"></ul>
    </div>
    <a href="/questions" class="mt-4 inline-flex items-center gap-2 text-sm text-indigo-600 hover:underline font-medium">
      → Savollar ro'yxatini ko'rish
    </a>
  </div>

</div>

<script>
const fileInput = document.getElementById('excelFile');
const fileNameEl = document.getElementById('fileName');

fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) {
    fileNameEl.textContent = fileInput.files[0].name;
    fileNameEl.classList.remove('text-gray-400');
    fileNameEl.classList.add('text-indigo-700', 'font-medium');
  }
});

// Drag and drop
const dropZone = document.getElementById('dropZone');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-indigo-400','bg-indigo-50'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-indigo-400','bg-indigo-50'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('border-indigo-400','bg-indigo-50');
  const file = e.dataTransfer.files[0];
  if (file && (file.name.endsWith('.xlsx') || file.name.endsWith('.xls'))) {
    const dt = new DataTransfer();
    dt.items.add(file);
    fileInput.files = dt.files;
    fileNameEl.textContent = file.name;
    fileNameEl.classList.add('text-indigo-700','font-medium');
  } else {
    alert('Faqat .xlsx yoki .xls fayl qabul qilinadi');
  }
});

document.getElementById('importForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!fileInput.files[0]) { alert('Fayl tanlang'); return; }

  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg> Yuklanmoqda...';

  const formData = new FormData();
  formData.append('excelFile', fileInput.files[0]);
  formData.append('defaultSubjectId', document.getElementById('defaultSubjectId').value);

  try {
    const res = await fetch('/questions/import', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.success) {
      document.getElementById('resCreated').textContent = data.results.created;
      document.getElementById('resSkipped').textContent = data.results.skipped;
      if (data.results.errors.length > 0) {
        document.getElementById('resErrors').classList.remove('hidden');
        const ul = document.getElementById('resErrorList');
        ul.innerHTML = data.results.errors.map(e => `<li>• ${e}</li>`).join('');
      }
      document.getElementById('resultBox').classList.remove('hidden');
      document.getElementById('resultBox').scrollIntoView({ behavior: 'smooth' });
    } else {
      alert('Xato: ' + data.message);
    }
  } catch { alert('Xato yuz berdi'); }
  finally {
    btn.disabled = false;
    btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/></svg> Yuklash va Import Qilish';
  }
});
</script>

<%- include('../partials/footer') %>
