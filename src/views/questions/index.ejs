<%- include('../partials/header') %>

<!-- Filters -->
<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 mb-5">
  <form method="GET" action="/questions" class="flex flex-wrap gap-3 items-end">
    <div class="flex-1 min-w-48">
      <label class="block text-xs font-medium text-gray-500 mb-1">Qidirish</label>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="Savol matni..."
        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"/>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Fan</label>
      <select name="subject" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">Barchasi</option>
        <% for (const s of subjects) { %>
          <option value="<%= s.id %>" <%= filters.subjectId == s.id ? 'selected' : '' %>><%= s.name %></option>
        <% } %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Qiyinlik</label>
      <select name="difficulty" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">Barchasi</option>
        <option value="easy" <%= filters.difficulty === 'easy' ? 'selected' : '' %>>Oson</option>
        <option value="medium" <%= filters.difficulty === 'medium' ? 'selected' : '' %>>O'rta</option>
        <option value="hard" <%= filters.difficulty === 'hard' ? 'selected' : '' %>>Qiyin</option>
      </select>
    </div>
    <button type="submit" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
      Qidirish
    </button>
    <% if (filters.search || filters.subjectId || filters.difficulty) { %>
      <a href="/questions" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-lg transition-colors">Tozalash</a>
    <% } %>
    <div class="ml-auto flex gap-2">
      <a href="/questions/import" class="bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg text-sm font-medium flex items-center gap-1.5 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/></svg>
        Import
      </a>
      <button onclick="openCreateModal()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-2 rounded-lg text-sm font-medium flex items-center gap-1.5 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Qo'shish
      </button>
    </div>
  </form>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-5 py-3 border-b border-gray-50 flex items-center justify-between">
    <p class="text-sm text-gray-500">Jami: <strong class="text-gray-800"><%= pagination.total %></strong> ta savol</p>
  </div>
  <% if (questions.length === 0) { %>
    <div class="text-center py-16 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="font-medium">Savol topilmadi</p>
    </div>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Savol</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Fan</th>
          <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Javob</th>
          <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Qiyinlik</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% questions.forEach((q, i) => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3 text-gray-400"><%= pagination.offset + i + 1 %></td>
          <td class="px-5 py-3 max-w-xs">
            <p class="text-gray-800 font-medium truncate" title="<%= q.text %>"><%= q.text %></p>
            <p class="text-xs text-gray-400 mt-0.5">
              A: <%= q.optionA.substring(0,25) %><%= q.optionA.length > 25 ? '…' : '' %> &nbsp;|&nbsp;
              B: <%= q.optionB.substring(0,25) %><%= q.optionB.length > 25 ? '…' : '' %>
            </p>
          </td>
          <td class="px-5 py-3 text-gray-600"><%= q.subject.name %></td>
          <td class="px-5 py-3 text-center">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-100 text-green-700 font-bold text-xs">
              <%= q.correctAnswer %>
            </span>
          </td>
          <td class="px-5 py-3 text-center">
            <% const dMap = { easy: ['Oson','bg-blue-50 text-blue-700'], medium: ['O\'rta','bg-yellow-50 text-yellow-700'], hard: ['Qiyin','bg-red-50 text-red-700'] } %>
            <% const [label, cls] = dMap[q.difficulty] || ['O\'rta','bg-yellow-50 text-yellow-700'] %>
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium <%= cls %>"><%= label %></span>
          </td>
          <td class="px-5 py-3 text-right">
            <div class="flex items-center justify-end gap-2">
              <button onclick='openEditModal(<%- JSON.stringify(q) %>)'
                class="text-gray-400 hover:text-indigo-600 p-1.5 rounded hover:bg-indigo-50 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <button onclick="deleteQuestion(<%= q.id %>)"
                class="text-gray-400 hover:text-red-600 p-1.5 rounded hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
  <div class="px-5 py-3 border-t border-gray-100 flex items-center justify-between">
    <p class="text-xs text-gray-500">
      <%= pagination.offset + 1 %>–<%= Math.min(pagination.offset + pagination.pageSize, pagination.total) %> / <%= pagination.total %>
    </p>
    <div class="flex gap-1">
      <% if (pagination.hasPrev) { %>
        <a href="?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&subject=<%= filters.subjectId || '' %>&difficulty=<%= filters.difficulty || '' %>"
           class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">← Oldingi</a>
      <% } %>
      <% if (pagination.hasNext) { %>
        <a href="?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&subject=<%= filters.subjectId || '' %>&difficulty=<%= filters.difficulty || '' %>"
           class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Keyingi →</a>
      <% } %>
    </div>
  </div>
  <% } %>
  <% } %>
</div>

<!-- Modal -->
<div id="questionModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 modal-backdrop" onclick="closeModal()"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl p-6 modal-box max-h-[90vh] overflow-y-auto">
    <h2 id="modalTitle" class="text-lg font-bold text-gray-800 mb-5"></h2>
    <form id="questionForm" class="space-y-4">
      <input type="hidden" id="qId">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fan <span class="text-red-500">*</span></label>
          <select id="qSubject" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <% for (const s of subjects) { %>
              <option value="<%= s.id %>"><%= s.name %></option>
            <% } %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Qiyinlik</label>
          <select id="qDifficulty" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="easy">Oson</option>
            <option value="medium" selected>O'rta</option>
            <option value="hard">Qiyin</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Savol matni <span class="text-red-500">*</span></label>
        <textarea id="qText" rows="2" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none" placeholder="Savol matnini kiriting..."></textarea>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">A varianti <span class="text-red-500">*</span></label>
          <input type="text" id="qA" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="A javob"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">B varianti <span class="text-red-500">*</span></label>
          <input type="text" id="qB" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="B javob"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">C varianti <span class="text-red-500">*</span></label>
          <input type="text" id="qC" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="C javob"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">D varianti <span class="text-red-500">*</span></label>
          <input type="text" id="qD" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="D javob"/>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">To'g'ri javob <span class="text-red-500">*</span></label>
        <div class="flex gap-2">
          <% ['A','B','C','D'].forEach(l => { %>
          <label class="flex items-center gap-1.5 cursor-pointer">
            <input type="radio" name="correctAnswer" value="<%= l %>" id="correct<%= l %>"
              class="text-indigo-600 focus:ring-indigo-500"/>
            <span class="text-sm font-semibold"><%= l %></span>
          </label>
          <% }) %>
        </div>
      </div>
      <p id="qError" class="text-red-500 text-sm hidden"></p>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Bekor qilish</button>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors">Saqlash</button>
      </div>
    </form>
  </div>
</div>

<script>
let qEditMode = false;

function openCreateModal() {
  qEditMode = false;
  document.getElementById('modalTitle').textContent = "Savol qo'shish";
  document.getElementById('qId').value = '';
  document.getElementById('qText').value = '';
  document.getElementById('qA').value = '';
  document.getElementById('qB').value = '';
  document.getElementById('qC').value = '';
  document.getElementById('qD').value = '';
  document.getElementById('qDifficulty').value = 'medium';
  document.querySelectorAll('input[name="correctAnswer"]').forEach(r => r.checked = false);
  document.getElementById('qError').classList.add('hidden');
  document.getElementById('questionModal').classList.remove('hidden');
  setTimeout(() => document.getElementById('qText').focus(), 100);
}

function openEditModal(q) {
  qEditMode = true;
  document.getElementById('modalTitle').textContent = "Savolni tahrirlash";
  document.getElementById('qId').value = q.id;
  document.getElementById('qSubject').value = q.subjectId;
  document.getElementById('qText').value = q.text;
  document.getElementById('qA').value = q.optionA;
  document.getElementById('qB').value = q.optionB;
  document.getElementById('qC').value = q.optionC;
  document.getElementById('qD').value = q.optionD;
  document.getElementById('qDifficulty').value = q.difficulty || 'medium';
  const r = document.getElementById('correct' + q.correctAnswer);
  if (r) r.checked = true;
  document.getElementById('qError').classList.add('hidden');
  document.getElementById('questionModal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('questionModal').classList.add('hidden');
}

document.getElementById('questionForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('qId').value;
  const correctAnswer = document.querySelector('input[name="correctAnswer"]:checked')?.value;
  const errEl = document.getElementById('qError');

  if (!correctAnswer) {
    errEl.textContent = "To'g'ri javobni tanlang"; errEl.classList.remove('hidden'); return;
  }

  const body = {
    subjectId: document.getElementById('qSubject').value,
    text: document.getElementById('qText').value.trim(),
    optionA: document.getElementById('qA').value.trim(),
    optionB: document.getElementById('qB').value.trim(),
    optionC: document.getElementById('qC').value.trim(),
    optionD: document.getElementById('qD').value.trim(),
    correctAnswer,
    difficulty: document.getElementById('qDifficulty').value,
  };

  const url = qEditMode ? `/questions/${id}` : '/questions';
  const method = qEditMode ? 'PUT' : 'POST';

  try {
    const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const data = await res.json();
    if (data.success) { location.reload(); }
    else { errEl.textContent = data.message; errEl.classList.remove('hidden'); }
  } catch { errEl.textContent = 'Xato yuz berdi'; errEl.classList.remove('hidden'); }
});

async function deleteQuestion(id) {
  if (!confirm("Bu savolni o'chirmoqchimisiz?")) return;
  const res = await fetch(`/questions/${id}`, { method: 'DELETE' });
  const data = await res.json();
  if (data.success) { location.reload(); }
  else { alert(data.message); }
}
</script>

<%- include('../partials/footer') %>
