<%- include('../partials/header') %>

<div class="flex items-center justify-between mb-5">
  <p class="text-sm text-gray-500">Jami: <strong><%= total %></strong> ta test</p>
  <a href="/generator" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center gap-2 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Yangi test
  </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <% if (tests.length === 0) { %>
    <div class="text-center py-16 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <p class="font-medium">Hali test yaratilmagan</p>
      <a href="/generator" class="mt-3 inline-block text-indigo-600 text-sm hover:underline">Test yaratish →</a>
    </div>
  <% } else { %>
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-100">
      <tr>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">#</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">Nomi</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">Fan</th>
        <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase">Variantlar</th>
        <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase">Savollar</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">Sana</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% tests.forEach((t, i) => { %>
      <tr class="hover:bg-gray-50 transition-colors">
        <td class="px-5 py-3.5 text-gray-400"><%= (page - 1) * 10 + i + 1 %></td>
        <td class="px-5 py-3.5 font-medium text-gray-800"><%= t.title %></td>
        <td class="px-5 py-3.5 text-gray-600"><%= t.subject.name %></td>
        <td class="px-5 py-3.5 text-center">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
            <%= t.totalVariants %>
          </span>
        </td>
        <td class="px-5 py-3.5 text-center">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
            <%= t.questionsPerVariant %>
          </span>
        </td>
        <td class="px-5 py-3.5 text-gray-500 text-xs">
          <%= new Date(t.createdAt).toLocaleString('uz-UZ') %>
        </td>
        <td class="px-5 py-3.5">
          <div class="flex items-center justify-end gap-1">
            <a href="/generator/<%= t.id %>" class="p-1.5 text-gray-400 hover:text-indigo-600 rounded hover:bg-indigo-50 transition-colors" title="Ko'rish">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </a>
            <a href="/generator/<%= t.id %>/download/tests" class="p-1.5 text-gray-400 hover:text-blue-600 rounded hover:bg-blue-50 transition-colors" title="Testlar yuklab olish">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </a>
            <a href="/generator/<%= t.id %>/download/key" class="p-1.5 text-gray-400 hover:text-green-600 rounded hover:bg-green-50 transition-colors" title="Kalit yuklab olish">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            </a>
            <a href="/generator/<%= t.id %>/download/excel" class="p-1.5 text-gray-400 hover:text-emerald-600 rounded hover:bg-emerald-50 transition-colors" title="Excel yuklab olish">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18M10 3v18M6 3h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V6a3 3 0 013-3z"/></svg>
            </a>
            <button onclick="deleteTest('<%= t.id %>')" class="p-1.5 text-gray-400 hover:text-red-600 rounded hover:bg-red-50 transition-colors" title="O'chirish">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="px-5 py-3 border-t border-gray-100 flex items-center justify-between">
    <p class="text-xs text-gray-500"><%= page %> / <%= totalPages %> sahifa</p>
    <div class="flex gap-1">
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">← Oldingi</a>
      <% } %>
      <% if (page < totalPages) { %>
        <a href="?page=<%= page + 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">Keyingi →</a>
      <% } %>
    </div>
  </div>
  <% } %>
  <% } %>
</div>

<script>
async function deleteTest(id) {
  if (!confirm("Bu testni o'chirmoqchimisiz? Barcha variant ma'lumotlari o'chadi.")) return;
  const res = await fetch(`/generator/${id}`, { method: 'DELETE' });
  const data = await res.json();
  if (data.success) location.reload();
  else alert(data.message);
}
</script>

<%- include('../partials/footer') %>
